# ─── JARVIS Configuration ─────────────────────────────────────
# Fill in your values here

# Ollama
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# Telegram Bot
# Ask @BotFather on Telegram for a new bot and paste the HTTP API token here
TELEGRAM_BOT_TOKEN=8419762726:AAGqdUE3buuVYuPVfH_D7guW5_XK_5XAP4M

# Neo4j Knowledge Graph
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=charan123
DATABASE = "laptopbot"
# ChromaDB Memory
CHROMA_DB_PATH=./jarvis/.chromadb

# Vision / OCR
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# GPU Monitoring
# Options: nvidia (uses nvidia-smi), wmi (Windows WMI fallback), none
GPU_BACKEND=nvidia

# JARVIS Behaviour
# Seconds to wait for more lines before treating input as complete command
MULTILINE_TIMEOUT=2.5

# Tool Storage
TOOLS_DIR=./jarvis/tools/generated
