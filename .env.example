# ─── JARVIS Configuration ─────────────────────────────────────
# Copy this to .env and fill in your values

# Ollama
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# Telegram Bot
# Ask @BotFather on Telegram for a new bot and paste the HTTP API token here
TELEGRAM_BOT_TOKEN=your_token_here

# Neo4j Knowledge Graph
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ChromaDB Memory
CHROMA_DB_PATH=./jarvis/.chromadb

# Vision
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# GPU Monitoring
# Options: nvidia (uses nvidia-smi), wmi (Windows WMI), none
GPU_BACKEND=nvidia

# JARVIS Behaviour
# How long to wait (seconds) for more lines before treating input as complete
MULTILINE_TIMEOUT=2.5

# Tool Storage
TOOLS_DIR=./jarvis/tools/generated
